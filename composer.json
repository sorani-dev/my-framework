{
  "name": "sorani/my-framework",
  "description": "A simple framework",
  "license": "MIT",
  "authors": [
    {
      "name": "sorani-dev",
      "email": "sorani.dev@outlook.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Sorani\\SimpleFramework\\": "src/Sorani/SimpleFramework",
      "App\\": "src/App"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "9.*",
    "squizlabs/php_codesniffer": "^3.6",
    "fakerphp/faker": "^1.9",
    "phpspec/prophecy-phpunit": "^2.5",
    "phpstan/phpstan": "^2.2"
  },
  "require": {
    "php": ">=8.2",
    "guzzlehttp/psr7": "2.*",
    "http-interop/response-sender": "^1.0",
    "mezzio/mezzio-fastroute": "^3",
    "twig/twig": "3.*",
    "php-di/php-di": "^7",
    "pagerfanta/pagerfanta": "^4",
    "intervention/image": "^4",
    "middlewares/whoops": "2.*",
    "pagerfanta/twig": "*",
    "robmorgan/phinx": "^0.16.11"
  }
}
